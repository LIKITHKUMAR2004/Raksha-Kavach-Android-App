<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_16dp">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/primary_blue"
            android:padding="@dimen/padding_20dp"
            android:layout_marginBottom="@dimen/padding_20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🛡️ RAKSHA-KAVACH"
                android:textSize="@dimen/text_heading"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                android:gravity="center"
                android:layout_marginBottom="@dimen/padding_8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Safety First - Your Workplace Protection"
                android:textSize="@dimen/text_medium"
                android:textColor="@color/primary_light_blue"
                android:gravity="center" />
        </LinearLayout>

        <!-- Welcome Message -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Your Task"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="@dimen/padding_16dp" />

        <!-- AI Smart Recommendation Section -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/padding_16dp"
            app:cardCornerRadius="@dimen/corner_radius_medium"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_16dp"
                android:background="@color/bg_white">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🤖 AI Smart Safety Generator"
                    android:textSize="@dimen/text_medium"
                    android:textStyle="bold"
                    android:textColor="@color/primary_blue"
                    android:layout_marginBottom="@dimen/padding_8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enter any task and get intelligent safety recommendations"
                    android:textSize="@dimen/text_small"
                    android:textColor="@color/text_light"
                    android:layout_marginBottom="@dimen/padding_12dp" />

                <EditText
                    android:id="@+id/editTextTask"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Example: welding, cricket, cooking"
                    android:padding="12dp"
                    android:layout_marginBottom="@dimen/padding_12dp" />

                <Button
                    android:id="@+id/buttonGenerateChecklist"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="Generate Smart Checklist"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:background="@color/primary_blue" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Welding Button Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/padding_12dp"
            app:cardCornerRadius="@dimen/corner_radius_medium"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/welding_light"
                android:padding="@dimen/padding_16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔥 WELDING SAFETY"
                    android:textSize="@dimen/text_medium"
                    android:textStyle="bold"
                    android:textColor="@color/welding_color"
                    android:layout_marginBottom="@dimen/padding_8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Check all welding precautions before starting work"
                    android:textSize="@dimen/text_small"
                    android:textColor="@color/text_light"
                    android:layout_marginBottom="@dimen/padding_12dp" />

                <Button
                    android:id="@+id/buttonWelding"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="Start Checklist"
                    android:textSize="@dimen/text_medium"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:background="@color/welding_color" />
            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>